{
  "name": "keiryu",
  "displayName": "Keiryu",
  "description": "渓流をテーマにしたダークカラーテーマ",
  "icon": "assets/screenshots/keiryu-icon.png",
  "version": "0.1.1",
  "publisher": "8mitsuboy",
  "repository": {
    "type": "git",
    "url": "https://github.com/8mitsuboy/Keiryu.git"
  },
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Themes"
  ],
  "keywords": [
    "theme",
    "dark",
    "japanese",
    "nature",
    "keiryu"
  ],
  "contributes": {
    "themes": [
      {
        "label": "Keiryu Dark",
        "uiTheme": "vs-dark",
        "path": "./themes/keiryu-dark.json"
      }
    ]
  },
  "scripts": {
    "build": "ts-node src/build.ts",
    "debug": "npm run build && npx vsce package && code --install-extension keiryu-0.1.0.vsix --force",
    "test": "tsc --noEmit && npm run build",
    "watch": "nodemon --watch src --ext ts --exec \"npm run build\""
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "nodemon": "^3.0.0",
    "ts-node": "^10.9.0",
    "typescript": "^5.0.0"
  }
}
