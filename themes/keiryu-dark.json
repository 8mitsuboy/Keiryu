  "tokenColors": [
    {
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#666152",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.operator.new",
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#c04848"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "support.function",
        "meta.function-call entity.name.function"
      ],
      "settings": {
        "foreground": "#587d86"
      }
    },
    {
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "entity.name.interface",
        "entity.name.enum",
        "support.type",
        "support.class"
      ],
      "settings": {
        "foreground": "#736985"
      }
    },
    {
      "scope": [
        "entity.name.tag",
        "meta.tag entity.name.tag",
        "meta.tag.custom entity.name.tag",
        "support.class.component"
      ],
      "settings": {
        "foreground": "#a96b46"
      }
    },
    {
      "scope": [
        "punctuation.definition.tag",
        "meta.tag punctuation",
        "punctuation.bracket.angle"
      ],
      "settings": {
        "foreground": "#454b3f"
      }
    },
    {
      "scope": [
        "entity.other.attribute-name",
        "entity.other.attribute-name.jsx",
        "meta.tag.attributes entity.other.attribute-name",
        "support.type.property-name"
      ],
      "settings": {
        "foreground": "#736985"
      }
    },
    {
      "scope": [
        "markup.heading.1",
        "markup.heading.1.markdown",
        "entity.name.section.markdown.1"
      ],
      "settings": {
        "foreground": "#c04848"
      }
    },
    {
      "scope": [
        "markup.heading.2",
        "markup.heading.2.markdown",
        "entity.name.section.markdown.2"
      ],
      "settings": {
        "foreground": "#a96b46"
      }
    },
    {
      "scope": [
        "markup.heading.3",
        "markup.heading.3.markdown",
        "entity.name.section.markdown.3"
      ],
      "settings": {
        "foreground": "#a7884a"
      }
    },
    {
      "scope": [
        "markup.heading.4",
        "markup.heading.4.markdown",
        "entity.name.section.markdown.4"
      ],
      "settings": {
        "foreground": "#587d86"
      }
    },
    {
      "scope": [
        "markup.heading",
        "markup.heading.markdown",
        "entity.name.section.markdown",
        "punctuation.definition.heading.markdown"
      ],
      "settings": {
        "foreground": "#454b3f"
      }
    },
    {
      "scope": [
        "markup.underline.link",
        "markup.underline.link.markdown",
        "string.other.link.title.markdown",
        "markup.link"
      ],
      "settings": {
        "foreground": "#587d86"
      }
    },
    {
      "scope": [
        "markup.inline.raw",
        "markup.inline.raw.markdown",
        "markup.fenced_code.block.markdown",
        "markup.raw.block.markdown"
      ],
      "settings": {
        "foreground": "#517860"
      }
    },
    {
      "scope": [
        "markup.quote",
        "markup.quote.markdown",
        "punctuation.definition.quote.begin.markdown"
      ],
      "settings": {
        "foreground": "#517860",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "string",
        "string.quoted",
        "string.template"
      ],
      "settings": {
        "foreground": "#517860"
      }
    },
    {
      "scope": [
        "constant.numeric",
        "constant.language.boolean",
        "constant.language.null",
        "constant.language.undefined"
      ],
      "settings": {
        "foreground": "#9b927d"
      }
    },
    {
      "scope": [
        "variable.other.property",
        "variable.other.object.property",
        "variable.parameter",
        "meta.parameters variable.other"
      ],
      "settings": {
        "foreground": "#517860"
      }
    },
    {
      "scope": [
        "entity.name.annotation",
        "entity.name.type.annotation",
        "meta.decorator",
        "meta.decorator entity.name.function",
        "meta.annotation",
        "punctuation.decorator",
        "punctuation.definition.annotation",
        "storage.type.annotation",
        "support.annotation",
        "meta.annotation entity.name.type"
      ],
      "settings": {
        "foreground": "#736985"
      }
    },
    {
      "scope": [
        "variable",
        "variable.other"
      ],
      "settings": {
        "foreground": "#b3a990"
      }
    },
    {
      "scope": [
        "keyword.operator"
      ],
      "settings": {
        "foreground": "#9b927d"
      }
    },
    {
      "scope": [
        "punctuation",
        "meta.brace"
      ],
      "settings": {
        "foreground": "#b3a990"
      }
    }
  ],
  "semanticTokenColors": {
    "function": "#587d86",
    "function.declaration": "#587d86",
    "method": "#587d86",
    "method.declaration": "#587d86",
    "class": "#736985",
    "interface": "#736985",
    "type": "#736985",
    "typeParameter": "#736985",
    "enum": "#736985",
    "enumMember": "#736985",
    "parameter": "#517860",
    "property": "#517860",
    "variable": "#b3a990",
    "variable.constant": "#9b927d",
    "keyword": "#c04848",
    "string": "#517860",
    "number": "#9b927d",
    "regexp": "#517860",
    "annotation": "#736985",
    "annotation.declaration": "#736985",
    "decorator": "#736985",
    "namespace": "#b3a990",
    "macro": "#736985"
  }
}
