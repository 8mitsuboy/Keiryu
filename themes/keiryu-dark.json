  "tokenColors": [
    {
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#666152",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.operator.new",
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#c06030"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "support.function",
        "meta.function-call entity.name.function"
      ],
      "settings": {
        "foreground": "#3d7870"
      }
    },
    {
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "entity.name.interface",
        "entity.name.enum",
        "support.type",
        "support.class"
      ],
      "settings": {
        "foreground": "#746b87"
      }
    },
    {
      "scope": [
        "string",
        "string.quoted",
        "string.template"
      ],
      "settings": {
        "foreground": "#3d7870"
      }
    },
    {
      "scope": [
        "constant.numeric",
        "constant.language.boolean",
        "constant.language.null",
        "constant.language.undefined"
      ],
      "settings": {
        "foreground": "#746b87"
      }
    },
    {
      "scope": [
        "variable.other.property",
        "variable.other.object.property",
        "variable.parameter",
        "meta.parameters variable.other"
      ],
      "settings": {
        "foreground": "#527860"
      }
    },
    {
      "scope": [
        "entity.name.annotation",
        "entity.name.type.annotation",
        "meta.decorator",
        "meta.decorator entity.name.function",
        "meta.annotation",
        "punctuation.decorator",
        "punctuation.definition.annotation",
        "storage.type.annotation",
        "support.annotation",
        "meta.annotation entity.name.type"
      ],
      "settings": {
        "foreground": "#746b87"
      }
    },
    {
      "scope": [
        "variable",
        "variable.other"
      ],
      "settings": {
        "foreground": "#b3a990"
      }
    },
    {
      "scope": [
        "keyword.operator"
      ],
      "settings": {
        "foreground": "#9b927d"
      }
    },
    {
      "scope": [
        "punctuation",
        "meta.brace"
      ],
      "settings": {
        "foreground": "#b3a990"
      }
    }
  ],
  "semanticTokenColors": {
    "function": "#3d7870",
    "function.declaration": "#3d7870",
    "method": "#3d7870",
    "method.declaration": "#3d7870",
    "class": "#746b87",
    "interface": "#746b87",
    "type": "#746b87",
    "typeParameter": "#746b87",
    "enum": "#746b87",
    "enumMember": "#746b87",
    "parameter": "#527860",
    "property": "#527860",
    "variable": "#b3a990",
    "variable.constant": "#746b87",
    "keyword": "#c06030",
    "string": "#3d7870",
    "number": "#746b87",
    "regexp": "#3d7870",
    "annotation": "#746b87",
    "annotation.declaration": "#746b87",
    "decorator": "#746b87",
    "namespace": "#b3a990",
    "macro": "#746b87"
  }
}
