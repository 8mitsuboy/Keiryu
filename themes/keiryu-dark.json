  "tokenColors": [
    {
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#6e6858",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.operator.new",
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#6a9080"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "support.function",
        "meta.function-call entity.name.function"
      ],
      "settings": {
        "foreground": "#b0945a"
      }
    },
    {
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "entity.name.interface",
        "entity.name.enum",
        "support.type",
        "support.class"
      ],
      "settings": {
        "foreground": "#b0945a"
      }
    },
    {
      "scope": [
        "string",
        "string.quoted",
        "string.template"
      ],
      "settings": {
        "foreground": "#7a9a6a"
      }
    },
    {
      "scope": [
        "constant.numeric",
        "constant.language.boolean",
        "constant.language.null",
        "constant.language.undefined"
      ],
      "settings": {
        "foreground": "#8878a0"
      }
    },
    {
      "scope": [
        "variable.other.property",
        "variable.other.object.property",
        "variable.parameter",
        "meta.parameters variable.other"
      ],
      "settings": {
        "foreground": "#a07850"
      }
    },
    {
      "scope": [
        "meta.decorator",
        "meta.decorator entity.name.function",
        "punctuation.decorator",
        "meta.annotation",
        "meta.annotation entity.name.type"
      ],
      "settings": {
        "foreground": "#a06858"
      }
    },
    {
      "scope": [
        "variable",
        "variable.other"
      ],
      "settings": {
        "foreground": "#bfb49a"
      }
    },
    {
      "scope": [
        "keyword.operator"
      ],
      "settings": {
        "foreground": "#a89e86"
      }
    },
    {
      "scope": [
        "punctuation",
        "meta.brace"
      ],
      "settings": {
        "foreground": "#bfb49a"
      }
    }
  ],
  "semanticTokenColors": {
    "function": "#b0945a",
    "function.declaration": "#b0945a",
    "method": "#b0945a",
    "method.declaration": "#b0945a",
    "class": "#b0945a",
    "interface": "#b0945a",
    "type": "#b0945a",
    "typeParameter": "#b0945a",
    "enum": "#b0945a",
    "enumMember": "#8878a0",
    "parameter": "#a07850",
    "property": "#a07850",
    "variable": "#bfb49a",
    "variable.constant": "#8878a0",
    "keyword": "#6a9080",
    "string": "#7a9a6a",
    "number": "#8878a0",
    "regexp": "#7a9a6a",
    "decorator": "#a06858",
    "namespace": "#bfb49a",
    "macro": "#6a9080"
  }
}
